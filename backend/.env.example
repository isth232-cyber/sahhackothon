APP_JWT_SECRET=<your-strong-random-secret-min-32-chars>
# JWT_SECRET is also supported for backward compatibility
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5437/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Provider: set to 'gemini' to use real AI, 'mock' for demo without API key
AI_PROVIDER=gemini
GEMINI_API_KEY=<your-gemini-api-key>
